# JWT Configuration - Generate a strong secret key
JWT_SECRET_KEY=your-super-secret-jwt-key-here-32-characters-at-least!
JWT_ALGORITHM=HS256

# CORS Configuration - Update with your frontend domain
ALLOWED_ORIGINS=https://magiclens.vercel.app,http://localhost:3000
ALLOWED_METHODS=GET,POST,OPTIONS,PUT,DELETE
ALLOWED_HEADERS=Authorization,Content-Type,X-Requested-With
ALLOW_CREDENTIALS=true

# Flow Blockchain Configuration
FLOW_NETWORK=testnet
FLOW_ACCESS_NODE=https://access-testnet.onflow.org
# FLOW_PRIVATE_KEY=your_flow_private_key_here

# Security
RATE_LIMIT_PER_MINUTE=60

# Environment
ENV=development

# Database (these are set in docker-compose.yml but can be overridden)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=magiclens
DB_USER=magiclens_user
DB_PASSWORD=magiclens_pass

# Redis (set in docker-compose.yml but can be overridden)
REDIS_URL=redis://redis:6379/0

# Upload validation
MAX_UPLOAD_SIZE_MB=200

# X Layer (EVM) — Frontend Env Vars (NEXT_PUBLIC_ required for Next.js client-side)
NEXT_PUBLIC_XLAYER_NETWORK=testnet
NEXT_PUBLIC_WORLDCUP_PACK_ADDRESS=0xff52Adf73e19fCd2B79784154CFf23b218CCEdfB
NEXT_PUBLIC_REMIX_NFT_ADDRESS=0x910d4383313814CC47db6ffeD56aC2F2CBE764Cf
NEXT_PUBLIC_FAN_CAST_REWARDS_ADDRESS=0x06A6C516D3FCeE59198Ff71186A1c77c00870aDD
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Pexels API (free, for stock sports clips in ClipPicker)
# Get yours at https://www.pexels.com/api/
PEXELS_API_KEY=