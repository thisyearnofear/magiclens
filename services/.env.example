# Flow — Network & Contract Configuration
# FLOW_NETWORK: emulator | testnet | mainnet
FLOW_NETWORK=testnet
FLOW_ACCESS_NODE=https://rest-testnet.onflow.org
FLOW_ARASSETNFT_ADDRESS=0x4520a5a7b69ee3ac
# Address of NonFungibleToken on the target network:
#   testnet: 0x631e88ae7f1d7c20
#   mainnet: 0x1d7e57aa55817448
FLOW_NFT_ADDRESS=0x631e88ae7f1d7c20
# Path to flow.json (must contain the service account key)
# For production, extract the key with: flow config extract-key --all
FLOW_JSON_PATH=./flow.json

# GIF API Keys for Overlay Search
TENOR_API_KEY=your_tenor_api_key_here
GIPHY_API_KEY=your_giphy_api_key_here
TENOR_CLIENT_KEY=augmented_reality_app
PEXELS_API_KEY=your_pexels_api_key_here

# Get your keys from:
# Tenor: https://developers.google.com/tenor/guides/quickstart
# Giphy: https://developers.giphy.com/
# Pexels: https://www.pexels.com/api/

# Other existing environment variables...
MEDIA_BUCKET=magiclens-media
MEDIA_REGION=us-east-1
LOCAL_MEDIA_DIR=/tmp/magiclens-media