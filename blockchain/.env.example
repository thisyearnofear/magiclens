# X Layer RPC endpoints
XLAYER_TESTNET_RPC=https://testrpc.xlayer.tech/terigon
XLAYER_MAINNET_RPC=https://rpc.xlayer.tech

# Deployer wallet private key (no 0x prefix)
XLAYER_DEPLOYER_PRIVATE_KEY=

# Block explorer API key for contract verification
XLAYER_EXPLORER_API_KEY=

# Reward token address (leave empty to use MockUSDT from deploy script)
# For production on X Layer testnet, set to canonical USDT address
REWARD_TOKEN_ADDRESS=

# Flow testnet account for cross-VM automation (optional for hackathon)
FLOW_TESTNET_PRIVATE_KEY=
