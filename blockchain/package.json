{
  "name": "magiclens-blockchain",
  "version": "1.0.0",
  "description": "MagicLens EVM contracts — World Cup AR overlay packs, remix NFTs, and fan rewards on X Layer",
  "main": "index.js",
  "scripts": {
    "compile": "npx hardhat compile",
    "test": "npx hardhat test",
    "deploy:xlayer-testnet": "npx hardhat run scripts/deploy.ts --network xlayerTestnet",
    "deploy:xlayer-mainnet": "npx hardhat run scripts/deploy.ts --network xlayerMainnet",
    "verify:xlayer-testnet": "npx hardhat verify --network xlayerTestnet"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "5.0.2",
    "dotenv": "^16.5.0",
    "hardhat": "^2.22.0",
    "typescript": "^5.6.0",
    "ts-node": "^10.9.0"
  }
}
